rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: only the authenticated user can read/write their own user doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Company document: only users whose user doc has companyId == companyId
    match /companies/{companyId} {
      // Allow initial company creation during registration, before the user doc
      // exists / before user.companyId is written.
      allow create: if request.auth != null;

      // After bootstrapping, reads/updates are strictly scoped to the user's companyId.
      allow read, update, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
    }

    // All subcollections under a company (loads, drivers, expenses, owners, receipts, etc.)
    match /companies/{companyId}/{document=**} {
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
    }

    // Legacy top-level collections (if still used): require auth only
    match /receipts/{receiptId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null;
    }
    match /units/{unitId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null;
    }
  }
}
